        protected void Set<T>(ref T field, T value, [CallerMemberName] string name = null)
        {
            if (System.Collections.Generic.EqualityComparer<T>.Default.Equals(field, value)) return;
            field = value;
            PropertyChanged?.Invoke(this, new PropertyChangedEventArgs(name));

            string label = (_propLabel.TryGetValue(name ?? "", out string lbl)) ? lbl : name;
            string valueStr = value is bool b ? (b ? "ON" : "OFF")
                            : value is double d ? d.ToString("G4")
                            : value?.ToString() ?? "null";
            OnSettingChanged?.Invoke($"[EasyMo] {label} → {valueStr}");
        }

