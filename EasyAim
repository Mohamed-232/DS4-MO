                gc > 3 && gates[3].Enable && gfN,
                $"[EasyMo] AntiRecoil v2 » Fire={viewmodel.AntiRecoilR2Value:F0}  ADS+Fire={viewmodel.AntiRecoilL2R2Value:F0}");

            LogOnChange(ref _logRapidFire,
                gc > 4 && gates[4].Enable && gfN,
