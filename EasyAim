            { if (cur && !prev) MacroBase.Print(msg); prev = cur; }

            LogOnChange(ref _logHairTrigger,
                gc > 1 && gates[1].Enable && (MacroBase.RealDS4.L2 > 0 || MacroBase.RealDS4.R2 > 0),
                $"[EasyMo] HairTrigger v2 » threshold={viewmodel.HairTriggerThreshold:F0}  amp={viewmodel.HairTriggerAmplification:F1}x");

