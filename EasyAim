    internal static class PluginLicenseInfo
    {
        private const string SupabaseUrl = "https://djclpbsmshhbrbqlgsyi.supabase.co";
        private const string AnonKey = "sb_publishable_CDsFH4nM8SnuF4c_e9WCcg_LHUfLVSW";

        private static readonly string CachePath = System.IO.Path.Combine(
            Environment.GetFolderPath(Environment.SpecialFolder.ApplicationData),
            "EasyAimImproved", "plugin_lic.dat");

        private static readonly System.Net.Http.HttpClient _http
            = new System.Net.Http.HttpClient();

        // ── HWID (mirrors HwidHelper in LicenseGate exactly) ─────────────────
        public static string GetHwid()
        {
            string raw = "";
            try
            {
                using (var regKey = Microsoft.Win32.Registry.LocalMachine.OpenSubKey(
                    @"SOFTWARE\Microsoft\Cryptography"))
                    raw += regKey?.GetValue("MachineGuid")?.ToString() ?? "";
            }
            catch { }
            raw += Environment.MachineName + Environment.UserDomainName;
            if (string.IsNullOrEmpty(raw)) raw = Environment.MachineName + Environment.UserName;

            using (var sha = System.Security.Cryptography.SHA256.Create())
            {
                byte[] hash = sha.ComputeHash(
                    System.Text.Encoding.UTF8.GetBytes(raw + "EasyAimHWID_v1"));
                return BitConverter.ToString(hash).Replace("-", "").Substring(0, 16);
            }
        }

        // ── AES key derived from HWID (mirrors LicenseCrypto) ────────────────
        private static byte[] MachineAesKey()
        {
            string raw = GetHwid() + "EasyAimAES_v1";
            using (var sha = System.Security.Cryptography.SHA256.Create())
                return sha.ComputeHash(System.Text.Encoding.UTF8.GetBytes(raw));
        }

        // ── Encrypt ───────────────────────────────────────────────────────────
        private static string Encrypt(string plain)
        {
            byte[] key = MachineAesKey();
            using (var aes = System.Security.Cryptography.Aes.Create())
            {
                aes.Key = key;
                aes.GenerateIV();
                using (var enc = aes.CreateEncryptor())
                {
                    byte[] data = System.Text.Encoding.UTF8.GetBytes(plain);
                    byte[] cipher = enc.TransformFinalBlock(data, 0, data.Length);
                    byte[] result = new byte[aes.IV.Length + cipher.Length];
                    Buffer.BlockCopy(aes.IV, 0, result, 0, aes.IV.Length);
                    Buffer.BlockCopy(cipher, 0, result, aes.IV.Length, cipher.Length);
                    return Convert.ToBase64String(result);
                }
            }
        }

        // ── Decrypt ───────────────────────────────────────────────────────────
        private static string Decrypt(string base64)
        {
            byte[] key = MachineAesKey();
            byte[] data = Convert.FromBase64String(base64);
            using (var aes = System.Security.Cryptography.Aes.Create())
            {
                aes.Key = key;
                byte[] iv = new byte[aes.BlockSize / 8];
                byte[] cipher = new byte[data.Length - iv.Length];
                Buffer.BlockCopy(data, 0, iv, 0, iv.Length);
                Buffer.BlockCopy(data, iv.Length, cipher, 0, cipher.Length);
                aes.IV = iv;
                using (var dec = aes.CreateDecryptor())
                {
                    byte[] plain = dec.TransformFinalBlock(cipher, 0, cipher.Length);
                    return System.Text.Encoding.UTF8.GetString(plain);
                }
            }
        }

        // ── Save / Load ───────────────────────────────────────────────────────
        public static void SaveKey(string key)
        {
            try
            {
                System.IO.Directory.CreateDirectory(
                    System.IO.Path.GetDirectoryName(CachePath)!);
                System.IO.File.WriteAllText(CachePath, Encrypt(key));
            }
            catch { }
        }

        public static string LoadKey()
        {
            try
            {
                if (!System.IO.File.Exists(CachePath)) return "";
                return Decrypt(System.IO.File.ReadAllText(CachePath));
            }
            catch { return ""; }
        }

        // ── Mask key for display  e.g.  ABCD****WXYZ ─────────────────────────
        public static string MaskKey(string key)
        {
            if (string.IsNullOrEmpty(key)) return "";
            if (key.Length <= 8) return "****";
            return key.Substring(0, 4) + "****" + key.Substring(key.Length - 4);
        }

        // ── Query Supabase — returns ready-to-print status string ─────────────
        public static async System.Threading.Tasks.Task<string> QueryStatusAsync(string licenseKey)
        {
            licenseKey = (licenseKey ?? "").Trim().ToUpperInvariant();
            if (string.IsNullOrEmpty(licenseKey))
                return "[License] No key entered — type your key and press Check.";

            try
            {
                string url = SupabaseUrl
                    + "/rest/v1/licenses"
                    + "?license_key=eq." + Uri.EscapeDataString(licenseKey)
                    + "&select=is_active,expires_at";

                using (var req = new System.Net.Http.HttpRequestMessage(
                    System.Net.Http.HttpMethod.Get, url))
                {
                    req.Headers.TryAddWithoutValidation("apikey", AnonKey);
                    req.Headers.TryAddWithoutValidation("Authorization", "Bearer " + AnonKey);

                    var resp = await _http.SendAsync(req);
                    string json = await resp.Content.ReadAsStringAsync();

                    if (!resp.IsSuccessStatusCode || json == "[]" || !json.Contains("is_active"))
                        return "[License] ✖  Key not found on server.";

                    if (!json.Contains("\"is_active\":true"))
                        return "[License] ✖  License is DISABLED. Contact support.";

                    // ── Parse expires_at ──────────────────────────────────────
                    if (json.Contains("\"expires_at\":\""))
                    {
                        int si = json.IndexOf("\"expires_at\":\"") + 14;
                        int ei = json.IndexOf("\"", si);
                        if (ei > si && DateTime.TryParse(
                                json.Substring(si, ei - si), null,
                                System.Globalization.DateTimeStyles.RoundtripKind,
                                out DateTime exp))
                        {
                            exp = exp.ToUniversalTime();
                            if (exp < DateTime.UtcNow)
                                return $"[License] ✖  EXPIRED on {exp:yyyy-MM-dd HH:mm} UTC.";

                            TimeSpan left = exp - DateTime.UtcNow;
                            string timeLeft = left.Days > 0
                                ? $"{left.Days}d {left.Hours}h {left.Minutes}m"
                                : $"{left.Hours}h {left.Minutes}m {left.Seconds}s";

                            return $"[License] ✔  ACTIVE" +
                                   $"  |  Key: {MaskKey(licenseKey)}" +
                                   $"  |  Expires: {exp:yyyy-MM-dd HH:mm} UTC" +
                                   $"  |  Time left: {timeLeft}";
                        }
                    }

                    // No expires_at → lifetime license
                    return $"[License] ✔  ACTIVE  |  Key: {MaskKey(licenseKey)}" +
                            "  |  Lifetime (no expiry)";
                }
            }
            catch (Exception ex)
            {
                return $"[License] Network error: {ex.Message}";
            }
        }
    }

