        private bool ReadButton(YYSwapButton btn)
        {
            switch (btn)
            {
                case YYSwapButton.Triangle: return MacroBase.RealDS4.Triangle;
                case YYSwapButton.Cross: return MacroBase.RealDS4.Cross;
                case YYSwapButton.Square: return MacroBase.RealDS4.Square;
                case YYSwapButton.Circle: return MacroBase.RealDS4.Circle;
                case YYSwapButton.L1: return MacroBase.RealDS4.L1;
                case YYSwapButton.R1: return MacroBase.RealDS4.R1;
                case YYSwapButton.L2: return MacroBase.RealDS4.L2 > 0;
                case YYSwapButton.R2: return MacroBase.RealDS4.R2 > 0;
                case YYSwapButton.L3: return MacroBase.RealDS4.L3;
                case YYSwapButton.R3: return MacroBase.RealDS4.R3;
                case YYSwapButton.Options: return MacroBase.RealDS4.Options;
                case YYSwapButton.Share: return MacroBase.RealDS4.Share;
                case YYSwapButton.TouchPad: return MacroBase.RealDS4.TouchButton;
                default: return false;
            }
        }

