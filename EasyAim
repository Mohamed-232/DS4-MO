        public static void ApplyResolutionToConfig(string filePath, int w, int h, int hz)
        {
            try
            {
                var lines = File.ReadAllLines(filePath);
                bool anyChange = false;
                var kwW = new[] { "ResolutionSizeX", "ResX", "FullscreenWidth", "ScreenWidth", "Width", "WindowWidth" };
                var kwH = new[] { "ResolutionSizeY", "ResY", "FullscreenHeight", "ScreenHeight", "Height", "WindowHeight" };
                var kwHz = new[] { "FrameRateLimit", "MaxFPS", "RefreshRate", "FramerateCap", "MaxFpsInGame" };
                for (int i = 0; i < lines.Length; i++)
                {
                    string trimmed = lines[i].TrimStart();
                    if (trimmed.StartsWith(";") || trimmed.StartsWith("//") || trimmed.StartsWith("#")) continue;
                    foreach (var kw in kwW) if (TryReplaceConfigValue(ref lines[i], kw, w.ToString())) anyChange = true;
                    foreach (var kw in kwH) if (TryReplaceConfigValue(ref lines[i], kw, h.ToString())) anyChange = true;
                    foreach (var kw in kwHz) if (TryReplaceConfigValue(ref lines[i], kw, hz.ToString())) anyChange = true;
                }
                if (anyChange) File.WriteAllLines(filePath, lines);
            }
            catch { }
        }

        private static bool TryReplaceConfigValue(ref string line, string key, string value)
        {
            int eq = line.IndexOf('=');
            if (eq < 0) return false;
            string beforeEq = line.Substring(0, eq);
            string baseKey;
            int atIdx = beforeEq.IndexOf('@');
            if (atIdx >= 0) baseKey = beforeEq.Substring(0, atIdx).Trim();
            else baseKey = beforeEq.Trim();
            if (!string.Equals(baseKey, key, StringComparison.OrdinalIgnoreCase)) return false;
            string afterEq = line.Substring(eq + 1);
            int commentIdx = afterEq.IndexOf(" //");
            string comment = commentIdx >= 0 ? afterEq.Substring(commentIdx) : "";
            line = $"{beforeEq}={value}{comment}";
            return true;
        }

