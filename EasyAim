    internal sealed class ColorAimEngine : IDisposable
    {
        public ColorAimActivation Activation { get; set; } = ColorAimActivation.ADSOnly;
        public ColorAimPreset Preset { get; set; } = ColorAimPreset.HexInput;
        public int HexTargetR { get; set; } = 255;
        public int HexTargetG { get; set; } = 0;
        public int HexTargetB { get; set; } = 255;
        public double LockStrength { get; set; } = 38.0;
        public double LockSpeed { get; set; } = 75.0;
        public int DetectionQuality { get; set; } = 3;
        public int CoastFrames { get; set; } = 6;
        public double HueTolerance { get; set; } = 0.0;
        public double HueTightened { get; set; } = 0.0;
        public double DeadZonePx { get; set; } = 4.0;
        public double AnchorUpdateSpeed { get; set; } = 0.12;
        public double VertBiasTopFraction { get; set; } = 0.45;
        public double HorizClampFactor { get; set; } = 0.55;
        public double CentroidBlend { get; set; } = 0.80;

        private double _anchorX, _anchorY;
        private bool _hasAnchor;
        private int _coastRemaining;
        private bool _hardLocked;
        private double _lockedHue;
        private int _lockFrames;
        private const int LockConfirmFrames = 2;
        private int _lostFrames;

        private (short dx, short dy)[] _spiral;
        private int _spiralLen;
        private int _cachedRadius = -1;
        private readonly ScreenScanner _scanner = new ScreenScanner();

        private static void GetPresetColor(ColorAimPreset p, out int r, out int g, out int b)
        {
            switch (p)
            {
                case ColorAimPreset.Red: r = 255; g = 0; b = 0; break;
                case ColorAimPreset.Pink: r = 255; g = 0; b = 255; break;
                case ColorAimPreset.White: r = 255; g = 255; b = 255; break;
                case ColorAimPreset.Yellow: r = 255; g = 255; b = 0; break;
                case ColorAimPreset.Cyan: r = 0; g = 255; b = 255; break;
                case ColorAimPreset.Orange: r = 255; g = 102; b = 0; break;
                case ColorAimPreset.Purple: r = 170; g = 0; b = 255; break;
                case ColorAimPreset.Green: r = 0; g = 255; b = 0; break;
                case ColorAimPreset.Black: r = 0; g = 0; b = 0; break;
                case ColorAimPreset.HeroRivals: r = 255; g = 60; b = 60; break;
                case ColorAimPreset.Fortnite: r = 255; g = 100; b = 0; break;
                case ColorAimPreset.Apex: r = 255; g = 70; b = 70; break;
                case ColorAimPreset.Warzone: r = 255; g = 80; b = 80; break;
                case ColorAimPreset.COD: r = 255; g = 0; b = 0; break;
                default: r = -1; g = -1; b = -1; break;
            }
        }

        private static void RgbToHsv(int r, int g, int b,
                                      out double h, out double s, out double v)
        {
            double rf = r / 255.0, gf = g / 255.0, bf = b / 255.0;
            double max = Math.Max(rf, Math.Max(gf, bf));
            double min = Math.Min(rf, Math.Min(gf, bf));
            double d = max - min;
            v = max; s = max < 1e-6 ? 0.0 : d / max;
            if (d < 1e-6) { h = 0; return; }
            if (max == rf) h = 60.0 * (((gf - bf) / d) % 6.0);
            else if (max == gf) h = 60.0 * (((bf - rf) / d) + 2.0);
            else h = 60.0 * (((rf - gf) / d) + 4.0);
            if (h < 0) h += 360.0;
        }

        private static double HueDiff(double a, double b)
        { double d = Math.Abs(a - b) % 360.0; return d > 180.0 ? 360.0 - d : d; }

        private static void QualityToThresholds(int q,
            out double hueTol, out double hueTight,
            out double satMin, out double valMin,
            out int minPixels, out bool edgeFilter)
        {
            q = Math.Clamp(q, 1, 5);
            hueTol = new[] { 35.0, 28.0, 20.0, 14.0, 9.0 }[q - 1];
            hueTight = hueTol * 0.55;
            satMin = new[] { 0.45, 0.55, 0.65, 0.72, 0.80 }[q - 1];
            valMin = new[] { 0.30, 0.40, 0.50, 0.55, 0.60 }[q - 1];
            minPixels = new[] { 2, 3, 4, 5, 7 }[q - 1];
            edgeFilter = q >= 3;
        }

        public unsafe bool Tick(
            bool ads, bool fire, int radius,
            int customR, int customG, int customB,
            ref byte virtRX, ref byte virtRY)
        {
            bool gate = Activation switch
            {
                ColorAimActivation.ADSOnly => ads,
                ColorAimActivation.ADSPlusFire => ads && fire,
                ColorAimActivation.FireOnly => fire,
                ColorAimActivation.Always => true,
                _ => false
            };
            if (!gate)
            {
                _anchorX = _anchorY = 0;
                _hasAnchor = false; _coastRemaining = 0;
                _hardLocked = false; _lockFrames = 0; _lostFrames = 0;
                return false;
            }

            int tR, tG, tB;
            if (Preset == ColorAimPreset.HexInput)
            { tR = HexTargetR; tG = HexTargetG; tB = HexTargetB; }
            else if (Preset == ColorAimPreset.Custom)
            { tR = customR; tG = customG; tB = customB; }
            else
            {
                GetPresetColor(Preset, out tR, out tG, out tB);
                if (tR < 0) { tR = customR; tG = customG; tB = customB; }
            }
            RgbToHsv(tR, tG, tB, out double targetH, out _, out _);

            QualityToThresholds(DetectionQuality,
                out double autoHueTol, out double autoHueTight,
                out double satMin, out double valMin,
                out int minPixels, out bool edgeFilter);

            double hueTol = (HueTolerance > 0.5) ? HueTolerance : autoHueTol;
            double activeTol = _hardLocked ? autoHueTight : hueTol;
            double activeHue = _hardLocked ? _lockedHue : targetH;

            RebuildSpiralIfNeeded(radius);
            var scr = System.Windows.Forms.Screen.PrimaryScreen.Bounds;
            int scx = scr.Width >> 1;
            int scy = scr.Height >> 1;
            int diam = radius * 2;
            _scanner.EnsureSize(diam);
            _scanner.Capture(scx, scy);

            int hitCount = 0;
            int bbMinX = diam, bbMaxX = 0;
            int bbMinY = diam, bbMaxY = 0;

            var bmd = _scanner.Lock(out byte* basePtr, out int stride);
            try
            {
                int len = _spiralLen;
                for (int i = 0; i < len; i++)
                {
                    short sdx = _spiral[i].dx, sdy = _spiral[i].dy;
                    int px = radius + sdx, py = radius + sdy;
                    byte* p = basePtr + py * stride + (px << 2);

                    RgbToHsv(p[2], p[1], p[0], out double pH, out double pS, out double pV);
                    if (HueDiff(pH, activeHue) > activeTol) continue;
                    if (pS < satMin || pV < valMin) continue;

                    if (edgeFilter && px > 0 && px < diam - 1 && py > 0 && py < diam - 1)
                    {
                        bool nM = NeighbourMatch(basePtr, stride, px, py - 1, activeHue, activeTol, satMin, valMin);
                        bool sM = NeighbourMatch(basePtr, stride, px, py + 1, activeHue, activeTol, satMin, valMin);
                        bool wM = NeighbourMatch(basePtr, stride, px - 1, py, activeHue, activeTol, satMin, valMin);
                        bool eM = NeighbourMatch(basePtr, stride, px + 1, py, activeHue, activeTol, satMin, valMin);
                        if (nM && sM && wM && eM) continue;
                    }

                    hitCount++;
                    if (px < bbMinX) bbMinX = px;
                    if (px > bbMaxX) bbMaxX = px;
                    if (py < bbMinY) bbMinY = py;
                    if (py > bbMaxY) bbMaxY = py;
                }

                if (hitCount < minPixels || bbMaxX < bbMinX || bbMaxY < bbMinY)
                { _scanner.Unlock(bmd); goto HandleNotDetected; }

                double bbCX = (bbMinX + bbMaxX) * 0.5;
                double bbHalfW = (bbMaxX - bbMinX) * 0.5;
                double bbH = bbMaxY - bbMinY;
                double horizClampPx = bbHalfW * HorizClampFactor;
                double vertBiasThresholdY = bbMinY + bbH * VertBiasTopFraction;

                double wSumX = 0, wSumY = 0, wTotal = 0;

                for (int i = 0; i < _spiralLen; i++)
                {
                    short sdx = _spiral[i].dx, sdy = _spiral[i].dy;
                    int px = radius + sdx, py = radius + sdy;
                    byte* p = basePtr + py * stride + (px << 2);

                    RgbToHsv(p[2], p[1], p[0], out double pH, out double pS, out double pV);
                    if (HueDiff(pH, activeHue) > activeTol) continue;
                    if (pS < satMin || pV < valMin) continue;
                    if (Math.Abs(px - bbCX) > horizClampPx) continue;

                    double vertW = (py <= vertBiasThresholdY) ? 3.0 : 1.0;
                    double hd = HueDiff(pH, activeHue);
                    double hueW = 1.0 - (hd / Math.Max(activeTol, 1.0));
                    double w = vertW * hueW;
                    wSumX += px * w;
                    wSumY += py * w;
                    wTotal += w;
                }

                _scanner.Unlock(bmd);
                bmd = null;

                double targetX, targetY;
                if (wTotal > 0)
                {
                    double wCX = wSumX / wTotal;
                    double wCY = wSumY / wTotal;
                    targetX = CentroidBlend * (wCX - radius) + (1.0 - CentroidBlend) * (bbCX - radius);
                    targetY = CentroidBlend * (wCY - radius) + (1.0 - CentroidBlend) * ((bbMinY + bbMaxY) * 0.5 - radius);
                }
                else
                {
                    targetX = bbCX - radius;
                    targetY = (bbMinY + bbMaxY) * 0.5 - radius;
                }

                if (!_hasAnchor)
                { _anchorX = targetX; _anchorY = targetY; _hasAnchor = true; }
                else
                {
                    double a = Math.Clamp(AnchorUpdateSpeed, 0.02, 1.0);
                    _anchorX = a * targetX + (1.0 - a) * _anchorX;
                    _anchorY = a * targetY + (1.0 - a) * _anchorY;
                }

                _coastRemaining = CoastFrames;
                _lostFrames = 0;

                if (!_hardLocked)
                {
                    _lockFrames++;
                    if (_lockFrames >= LockConfirmFrames)
                    { _lockedHue = activeHue; _hardLocked = true; }
                }

                goto ApplyOutput;
            }
            finally { if (bmd != null) _scanner.Unlock(bmd); }

        HandleNotDetected:
            _lostFrames++;
            if (_lostFrames <= CoastFrames && _hasAnchor) { /* coast */ }
            else
            {
                _hasAnchor = false; _hardLocked = false;
                _lockFrames = 0; _lostFrames = 0; _anchorX = _anchorY = 0;
                return false;
            }

        ApplyOutput:
            if (!_hasAnchor) return false;

            double dist = Math.Sqrt(_anchorX * _anchorX + _anchorY * _anchorY);
            if (dist < DeadZonePx) return true;

            double ux = _anchorX / dist;
            double uy = _anchorY / dist;
            double lockMag = (LockStrength / 100.0) * 127.0;

            int dX = (int)Math.Round(ux * lockMag);
            int dY = (int)Math.Round(uy * lockMag);

            virtRX = (byte)Math.Clamp(virtRX + dX, 0, 255);
            virtRY = (byte)Math.Clamp(virtRY + dY, 0, 255);

            return true;
        }

        private static unsafe bool NeighbourMatch(
            byte* basePtr, int stride, int px, int py,
            double targetH, double hueTol, double satMin, double valMin)
        {
            byte* p = basePtr + py * stride + (px << 2);
            RgbToHsv(p[2], p[1], p[0], out double h, out double s, out double v);
            return HueDiff(h, targetH) <= hueTol && s >= satMin && v >= valMin;
        }

        private void RebuildSpiralIfNeeded(int radius)
        {
            if (radius == _cachedRadius) return;
            _cachedRadius = radius;
            int r2 = radius * radius;
            int cap = radius * 2 * radius * 2;
            var tmp = new (int d2, short dx, short dy)[cap];
            int cnt = 0;
            for (int dy = -radius + 1; dy < radius; dy++)
                for (int dx = -radius + 1; dx < radius; dx++)
                {
                    int d2 = dx * dx + dy * dy;
                    if (d2 > r2) continue;
                    tmp[cnt++] = (d2, (short)dx, (short)dy);
                }
            Array.Sort(tmp, 0, cnt,
                Comparer<(int d2, short dx, short dy)>.Create((a, b) => a.d2.CompareTo(b.d2)));
            _spiral = new (short, short)[cnt];
            _spiralLen = cnt;
            for (int i = 0; i < cnt; i++) _spiral[i] = (tmp[i].dx, tmp[i].dy);
        }

        public void Dispose() => _scanner.Dispose();
    }

