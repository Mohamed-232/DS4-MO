                gc > 5 && gates[5].Enable && ReadButton(viewmodel.SpamActivationSelectedItem),
                $"[EasyMo] Rapid Spam » {viewmodel.SpamActivationSelectedItem}→{viewmodel.SpamTargetSelectedItem}");

            LogOnChange(ref _logStab,
                gc > 6 && gates[6].Enable && viewmodel.StabilizerModeSelectedItem != StabilizerMode.Off && adsN,
                $"[EasyMo] Stabilizer » mode={viewmodel.StabilizerModeSelectedItem}  str={viewmodel.StabilizerStrength:F2}");

            LogOnChange(ref _logColorAim,
                gc > 7 && gates[7].Enable && adsN,
                $"[EasyMo] Color Aim v6 » preset={viewmodel.ProColorAimPresetSelectedItem}  FOV={viewmodel.FovRadiusPx}px  str={viewmodel.ProLockStrength:F0}%");

            LogOnChange(ref _logSmoother,
                gc > 8 && gates[8].Enable && adsN,
                $"[EasyMo] Smoother » α={viewmodel.ProAimAlpha:F2}  β={viewmodel.ProAimBeta:F2}");

            LogOnChange(ref _logMagnet,
                gc > 9 && gates[9].Enable && adsN,
                $"[EasyMo] Sticky Aim » magnet={viewmodel.ProMagnetStrength:F2}  r={viewmodel.ProMagnetRadius:F0}px");

            LogOnChange(ref _logRecoilEng,
                gc > 10 && gates[10].Enable && gfN,
                $"[EasyMo] Recoil Engine » global={viewmodel.ProRecoilGlobal:F2}  ADS={viewmodel.ProRecoilADS:F2}");

            LogOnChange(ref _logPattern,
                gc > 11 && gates[11].Enable && _activationEngine.IsActive(
                    viewmodel.ProPatternActivationModeSelectedItem, adsN, gfN),
                $"[EasyMo] Aim Pattern » mode={viewmodel.ProPatternModeSelectedItem}  amp={viewmodel.ProPatternAmplitude:F2}");

            LogOnChange(ref _logActMode,
                gc > 12 && gates[12].Enable,
                $"[EasyMo] Override Mode » {viewmodel.ProActivationModeSelectedItem}");
        }

