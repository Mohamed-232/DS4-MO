        private void SetFovOverlayVisible(bool show)
        {
            if (show)
            {
                if (_fovOverlay == null || !_fovOverlay.IsLoaded)
                    _fovOverlay = new FovOverlayWindow();
                RefreshFovOverlay();
                if (!_fovOverlay.IsVisible) _fovOverlay.Show();
                _fovOverlayVisible = true;
            }
            else
            {
                if (_fovOverlay != null && _fovOverlay.IsVisible)
                    _fovOverlay.Hide();
                _fovOverlayVisible = false;
            }
        }

        private void RefreshFovOverlay()
        {
            if (_fovOverlay == null) return;
            byte alpha = (byte)Math.Clamp(viewmodel.ProFovOverlayOpacity, 0, 255);
            System.Windows.Media.Color col = System.Windows.Media.Color.FromArgb(alpha, 255, 0, 255);
            if (TryParseHex(viewmodel.ProFovOverlayHexColor, out int hr, out int hg, out int hb))
                col = System.Windows.Media.Color.FromArgb(alpha, (byte)hr, (byte)hg, (byte)hb);
            _fovOverlay.Refresh(viewmodel.FovRadiusPx, col, viewmodel.ProFovOverlayThickness);
        }

