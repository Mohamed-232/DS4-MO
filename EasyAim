        private void MacroStabilizer(bool ads, bool gunfire)
        {
            if (Macro_StabFlow == null)
            {
                Macro_StabFlow = new FlowControllerV0("Stabilizer", null)
                {
                    new ActionInfoV0(() =>
                    {
                        bool adsN = ADS_Button();
                        bool gfN  = Gunfire_Button();
                        int  sx   = MacroBase.VirtualDS4.RX - 128;
                        int  sy   = MacroBase.VirtualDS4.RY - 128;
                        var (dx, dy) = _stabilizerEngine.Tick(adsN, gfN, sx, sy);
                        if (dx != 0 || dy != 0)
                        {
                            MacroBase.VirtualDS4.RX = (byte)Math.Clamp(MacroBase.VirtualDS4.RX + dx, 0, 255);
