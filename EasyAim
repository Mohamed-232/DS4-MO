        public override void UpdateState()
        {
            if (!base.MainGate.Enable) return;

            // ── Periodic license check (every 5 minutes) ──────────────────────
            long nowTick = Environment.TickCount64;
            if (nowTick - _lastLicenseLogTick >= LicenseLogMs)
            {
                _lastLicenseLogTick = nowTick;
                string keySnap = viewmodel.PluginLicenseKey;
                if (!string.IsNullOrEmpty(keySnap))
                    System.Threading.Tasks.Task.Run(async () =>
                    {
                        string status = await PluginLicenseInfo.QueryStatusAsync(keySnap);
                        MacroBase.Print(status);
                    });
            }

            bool ads = ADS_Button();
            bool gunfire = Gunfire_Button();
            var gates = base.MainGate.GateBaseList;
            int gc = gates.Count;

            ApplyProSettings(gates, gc);

            if (gc > 1 && gates[1].Enable) Macro0_HairTrigger();
            if (gc > 2 && gates[2].Enable) Macro1_AutoSprint(ads, gunfire);
            if (gc > 4 && gates[4].Enable) Macro3_RapidFire(gunfire);
            if (gc > 5 && gates[5].Enable) MacroSpam_RapidSpam(ads, gunfire);
            if (gc > 6 && gates[6].Enable) MacroStabilizer(ads, gunfire);
            if (gc > 3 && gates[3].Enable) Macro2_YAxisAntiRecoilPRO(gunfire, ads);
            if (gc > 7 && gates[7].Enable) Macro5_ColorAimAssistPRO(ads, gunfire);
            if (gc > 11 && gates[11].Enable) Macro9_AimPattern(ads, gunfire);

            MacroLog_Features(ads, gunfire, gc, gates);
        }

        private void ApplyProSettings(dynamic gates, int gc)
        {
            if (gc > 7 && gates[7].Enable)
            {
                _colorAimEngine.Activation = viewmodel.ProColorAimActivationSelectedItem;
                _colorAimEngine.Preset = viewmodel.ProColorAimPresetSelectedItem;
                _colorAimEngine.LockStrength = viewmodel.ProLockStrength;
                _colorAimEngine.DetectionQuality = (int)viewmodel.ProDetectionQuality;
                _colorAimEngine.CoastFrames = (int)viewmodel.ProDetectionQuality * 2;
                _colorAimEngine.HueTolerance = 0.0;
                _colorAimEngine.HueTightened = 0.0;
                double t = viewmodel.ProTrackingSpeed / 100.0;
                _colorAimEngine.AnchorUpdateSpeed = 0.02 + t * 0.38;
                _colorAimEngine.LockSpeed = viewmodel.ProTrackingSpeed;
                _colorAimEngine.DeadZonePx = viewmodel.ProDeadZonePx;
                _colorAimEngine.HorizClampFactor = viewmodel.ProHorizClampFactor;
                _colorAimEngine.VertBiasTopFraction = viewmodel.ProVertBiasTop;
                _colorAimEngine.CentroidBlend = viewmodel.ProCentroidBlend;

                if (TryParseHex(viewmodel.ProHexColorTarget, out int hr, out int hg, out int hb))
                {
                    _colorAimEngine.HexTargetR = hr;
                    _colorAimEngine.HexTargetG = hg;
                    _colorAimEngine.HexTargetB = hb;
                }
                if (viewmodel.ProFovOverlayEnabled)
                    System.Windows.Application.Current?.Dispatcher.InvokeAsync(
                        () => RefreshFovOverlay());
            }
            if (gc > 8 && gates[8].Enable)
                _colorAimEngine.AnchorUpdateSpeed = viewmodel.ProAimAlpha * 0.20;
            if (gc > 9 && gates[9].Enable)
                _colorAimEngine.DeadZonePx = viewmodel.ProMagnetRadius * 0.3;
            if (gc > 10 && gates[10].Enable)
            {
                _recoilEngine.GlobalMultiplier = viewmodel.ProRecoilGlobal;
                _recoilEngine.ADSMultiplier = viewmodel.ProRecoilADS;
                _recoilEngine.HipfireMultiplier = viewmodel.ProRecoilHipfire;
                _recoilEngine.SmoothAlpha = viewmodel.ProRecoilSmooth;
                _recoilEngine.DynamicRampRate = viewmodel.ProRecoilRampRate;
                _recoilEngine.DynamicMax = viewmodel.ProRecoilDynamicMax;
                _recoilEngine.WindDownRate = viewmodel.ProRecoilWindDown;
                _recoilEngine.EarlyBoostStrength = viewmodel.ProRecoilEarlyBoost;
                _recoilEngine.EarlyBoostShots = (int)viewmodel.ProRecoilEarlyShots;
                _recoilEngine.HorizCompensation = viewmodel.ProRecoilHorizComp;
                _recoilEngine.BurstResetMs = (int)viewmodel.ProRecoilBurstResetMs;
            }
            if (gc > 12 && gates[12].Enable)
            {
                _colorAimEngine.Activation = viewmodel.ProActivationModeSelectedItem switch
                {
                    ActivationMode.ADS => ColorAimActivation.ADSOnly,
                    ActivationMode.ADSPlusFire => ColorAimActivation.ADSPlusFire,
                    ActivationMode.Fire => ColorAimActivation.FireOnly,
                    _ => ColorAimActivation.Always,
                };
                _activationEngine.TimedDurationMs = (int)viewmodel.ProTimedDurationMs;
            }

            _stabilizerEngine.Mode = viewmodel.StabilizerModeSelectedItem;
            _stabilizerEngine.Strength = viewmodel.StabilizerStrength;
            _stabilizerEngine.Speed = viewmodel.StabilizerSpeed;
            if (gc > 6 && gates[6].Enable)
            {
                var sg = gates[6].GateBaseList;
                _stabilizerEngine.OnlyADS = sg.Count < 1 || sg[0].Enable;
                _stabilizerEngine.OnlyFire = sg.Count >= 2 && sg[1].Enable;
            }

            _hairTriggerEngine.ActivationThreshold = (byte)Math.Clamp(viewmodel.HairTriggerThreshold, 1, 254);
            _hairTriggerEngine.Amplification = viewmodel.HairTriggerAmplification;
            if (gc > 1 && gates[1].Enable)
            {
                var sg = gates[1].GateBaseList;
                _hairTriggerEngine.ProgressiveFill = sg.Count < 1 || sg[0].Enable;
            }

            _rapidSpamEngine.ActivationButton = viewmodel.SpamActivationSelectedItem;
            _rapidSpamEngine.TargetButton = viewmodel.SpamTargetSelectedItem;
            _rapidSpamEngine.PressMs = (int)viewmodel.SpamPressMs;
            _rapidSpamEngine.ReleaseMs = (int)viewmodel.SpamReleaseMs;
