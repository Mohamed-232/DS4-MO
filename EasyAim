        private void Macro0_HairTrigger()
        {
            if (MacroBase.RealDS4.L2 > 0)
                MacroBase.VirtualDS4.L2 = _hairTriggerEngine.Process(MacroBase.RealDS4.L2);
            if (MacroBase.RealDS4.R2 > 0)
                MacroBase.VirtualDS4.R2 = _hairTriggerEngine.Process(MacroBase.RealDS4.R2);
        }

        private bool LStickPush(bool ads, bool gunfire)
        {
            int lx = MacroBase.RealDS4.LX - 128, ly = MacroBase.RealDS4.LY - 128;
            return MacroBase.RealDS4.LY < 128 && !MacroBase.RealDS4.L1
                && !ads && !gunfire && lx * lx + ly * ly > 64 * 64;
        }

        private void Macro1_AutoSprint(bool ads, bool gunfire)
        {
            Macro1_Flow.Start_Condition = LStickPush(ads, gunfire) && CT["AutoSprint"].Elapsed(100);
            Macro1_Flow.Stop_Condition = MacroBase.RealDS4.L1 || ads || gunfire;
            Macro1_Flow.Repeat_Condition = false;
            Macro1_Flow.ExecuteMacro();
        }

        private void Macro2_YAxisAntiRecoilPRO(bool gunfire, bool ads)
        {
            if (Macro2_Flow == null)
            {
                Macro2_Flow = new FlowControllerV0("AntiRecoil", null)
                {
                    new ActionInfoV0(() =>
                    {
                        var gl   = base.MainGate.GateBaseList;
                        bool inv = gl.Count > 3 && gl[3].GateBaseList.Count > 0
                                   && gl[3].GateBaseList[0].Enable;
                        _recoilEngine.InvertY = inv;

                        bool adsN = ADS_Button();
                        bool gfN  = Gunfire_Button();

                        double sliderStrength = (adsN && gfN)
                            ? viewmodel.AntiRecoilL2R2Value
                            : viewmodel.AntiRecoilR2Value;

                        var gates2 = base.MainGate.GateBaseList;
                        bool proOn = gates2.Count > 10 && gates2[10].Enable;
                        _recoilEngine.GlobalMultiplier = proOn
                            ? viewmodel.ProRecoilGlobal : _globalRecoilMultiplier;

                        _recoilEngine.Tick(gfN, adsN, sliderStrength, out int dX, out int dY);

                        MacroBase.VirtualDS4.RY = (byte)Math.Clamp(MacroBase.VirtualDS4.RY + dY, 0, 255);
                        MacroBase.VirtualDS4.RX = (byte)Math.Clamp(MacroBase.VirtualDS4.RX + dX, 0, 255);
                    }, 16)
                };
            }
            Macro2_Flow.Start_Condition = gunfire && CT["AntiRecoil"].Elapsed(16);
            Macro2_Flow.Stop_Condition = !gunfire;
            Macro2_Flow.Repeat_Condition = true;
            Macro2_Flow.ExecuteMacro();
        }

        private void Macro3_RapidFire(bool gunfire)
        {
            if (Macro3_Flow == null)
            {
                bool useR2 = viewmodel.GunfireComboBoxSelectedItem == Gunfire.R2;
                var flow = new FlowControllerV0("RapidFire", null);
                if (useR2)
                {
                    flow.Add(new ActionInfoV0(() => { MacroBase.VirtualDS4.R2 = byte.MaxValue; }, 25));
                    flow.Add(new ActionInfoV0(() => { MacroBase.VirtualDS4.R2 = 0; }, () => (int)viewmodel.RapidFireValue));
                }
                else
                {
                    flow.Add(new ActionInfoV0(() => { MacroBase.VirtualDS4.R1 = true; }, 25));
                    flow.Add(new ActionInfoV0(() => { MacroBase.VirtualDS4.R1 = false; }, () => (int)viewmodel.RapidFireValue));
                }
                Macro3_Flow = flow;
            }
            bool can = gunfire && !MacroBase.RealDS4.R1;
            Macro3_Flow.Start_Condition = can;
            Macro3_Flow.Stop_Condition = !can;
            Macro3_Flow.Repeat_Condition = true;
            Macro3_Flow.ExecuteMacro();
        }

        private bool _spamPrevHeld = false;

        private void MacroSpam_RapidSpam(bool ads, bool gunfire)
        {
            bool held = ReadButton(viewmodel.SpamActivationSelectedItem);
            if (!held) { if (_spamPrevHeld) _rapidSpamEngine.Reset(); _spamPrevHeld = false; return; }
            _spamPrevHeld = true;
